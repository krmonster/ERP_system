# ============================================================================
# .gitignore — Git 版本控制忽略清单
# ----------------------------------------------------------------------------
# 用途:告诉 Git "这些文件不要追踪、不要提交"
# 适用阶段:阶段 1(W1-W6)。后续阶段会陆续追加新规则
# 语法说明:
#     文件夹名加 /  → 忽略整个文件夹
#     *.xxx        → 忽略所有以 .xxx 结尾的文件
#     # 开头        → 注释行
# ============================================================================

# ---------- Python 自动生成的垃圾文件 ----------
__pycache__/              # Python 字节码缓存目录,每次运行自动生成
*.pyc                     # Python 编译后的字节码文件
*.pyo                     # Python 优化后的字节码文件

# ---------- IDE / 编辑器配置(每个人本地的,不该共享) ----------
.idea/                    # PyCharm 的项目配置目录
.vscode/                  # VSCode 的项目配置目录
*.swp                     # Vim 编辑器的临时文件

# ---------- 操作系统垃圾 ----------
.DS_Store                 # macOS 自动生成的目录元信息(防止你以后用 Mac 时弄脏仓库)
Thumbs.db                 # Windows 自动生成的缩略图缓存

# ---------- 业务数据(绝对不能进 Git!!!) ----------
data/                     # 真实订单 Excel 数据存放目录
*.xlsx                    # 任何 Excel 文件都不进仓库(防止误操作)
~$*                       # Excel 打开时生成的临时锁文件(以 ~$ 开头)

# ---------- 日志 ----------
logs/                     # W2 开始,日志会输出到这个目录
*.log                     # 任何 .log 文件

# ---------- 虚拟环境(虽然我们的环境在 E:\Anaconda\envs\,不在项目里,但保险起见) ----------
venv/
.env                      # 环境变量文件(将来可能用来存数据库密码,绝对不能进 Git)